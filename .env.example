# ReachIQ CRM Environment Variables

# Channel Service endpoints
CHANNEL_SERVICE_URL=http://localhost:3001
CRM_RECEIPT_URL=http://localhost:3000/api/receipt

# Gemini API Key (Required for active AI features, otherwise falls back to mock)
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase Credentials (Required for active Supabase integration, otherwise falls back to local JSON DB)
SUPABASE_URL=
SUPABASE_ANON_KEY=
